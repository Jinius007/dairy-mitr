# Zoho Catalyst + Sarvam AI (feature branch)
# Copy to .env.local:  cp .env.example .env.local
# Or run:             npm run setup:catalyst

# Local dev (Vite proxy to catalyst serve):
VITE_CATALYST_API_URL=http://localhost:8080/catalyst-api

# Cloud deploy — copy URL from `catalyst deploy` output (India DC uses .catalystserverless.in)
VITE_CATALYST_API_URL=https://project-rainfall-60075686570.development.catalystserverless.in/server/pashumitra_api

# Catalyst function secrets → Zoho Console → Functions → pashumitra_api → Environment
# (or catalyst/functions/pashumitra_api/.env for local serve)
# SARVAM_API_KEY=required
# SARVAM_CHAT_MODEL=sarvam-30b
# SARVAM_STT_MODEL=saaras:v3
# SARVAM_TTS_SPEAKER=suhani
# SARVAM_TTS_CALL_SPEAKER=suhani
# SARVAM_TTS_PACE=0.93
# SARVAM_TTS_CALL_PACE=0.88
# BHASHINI_API_KEY=optional
# YOUTUBE_API_KEY=optional

# Sarvam RAG (curated NDDB/DAHD/ICAR corpus)
# 1. npm run build:knowledge       → extension PDFs + DAHD
# 2. npm run ingest:sarvam-rag     → ICAR + NDDB web (+ optional Vision OCR)
# 3. npm run ingest:sarvam-rag -- --vision   (Hindi/Gujarati PDFs via Sarvam Vision, needs SARVAM_API_KEY)
# SARVAM_VISION_PDF_LIMIT=12       # max PDFs per vision ingest run
# SARVAM_VISION_INGEST=1           # same as --vision flag

# Optional: Catalyst QuickML RAG (semantic search over QuickML knowledge base)
# Upload NDDB/ICAR docs in Catalyst Console → QuickML → Knowledge Base → RAG → View API
# QUICKML_RAG_URL=                 # POST endpoint from View API
# QUICKML_OAUTH_TOKEN=             # Zoho OAuth token (scope: QuickML.deployment.READ)
# QUICKML_ENDPOINT_KEY=            # X-QUICKML-ENDPOINT-KEY header (if shown in View API)
# CATALYST_ORG_ID=                 # CATALYST-ORG header
# QUICKML_ENVIRONMENT=Development  # or Production
# QUICKML_RAG_DOCUMENT_IDS=        # optional comma-separated doc IDs to limit search

# Vobiz (WhatsApp + phone) — see docs/VOBIZ_INTEGRATION.md
# VOBIZ_AUTH_ID=
# VOBIZ_AUTH_TOKEN=
# VOBIZ_WEBHOOK_SECRET=
# VOBIZ_CHANNEL_ID=
# VOBIZ_WHATSAPP_FROM=+91XXXXXXXXXX

# Data Store table: catalyst/datastore/conversation_turns.schema.json
