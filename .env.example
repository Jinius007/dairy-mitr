VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Vercel only — conversation logging (api/log-turn.js → Supabase conversation_turns)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — Vercel TTS quality (api/tts.js). Ration Advisor falls back to free browser speech if unset.
# BHASHINI_API_KEY=your-32-char-bhashini-api-key

# LiveAvatar photorealistic lip-sync (api/liveavatar-session.js + call button)
# 1. Create account at https://liveavatar.com
# 2. Upload public/pashu-advisor-avatar.jpeg as a custom Image Avatar → copy avatar UUID
# 3. Register ElevenLabs API key (paid plan required):
#    curl -X POST https://api.liveavatar.com/v1/secrets \
#      -H "X-API-KEY: YOUR_LIVEAVATAR_KEY" -H "content-type: application/json" \
#      -d '{"secret_type":"ELEVENLABS_API_KEY","secret_value":"YOUR_EL_KEY","secret_name":"PashuMitra"}'
# 4. Set on Vercel (server-side only — never expose LIVEAVATAR_API_KEY in VITE_* vars):
# LIVEAVATAR_API_KEY=your-liveavatar-api-key
# LIVEAVATAR_AVATAR_ID=uuid-from-step-2
# ELEVENLABS_LIVEAVATAR_SECRET_ID=secret_id-from-step-3
# ELEVENLABS_AGENT_ID=agent_0101ks38f27hec4tdtact1ejxx7t
# LIVEAVATAR_SANDBOX=true

# Supabase Edge Functions secrets — only needed for Chat/Call voice (not Ration Advisor)
# LOVABLE_API_KEY=your-lovable-or-gemini-key
# YOUTUBE_API_KEY=your-youtube-data-api-v3-key
#
# Ration Advisor uses built-in browser speech (Chrome/Edge) — no extra API keys required.
#
# Table: run supabase/setup.sql once in SQL Editor → conversation_turns
# View logs: Supabase → Table Editor → conversation_turns
