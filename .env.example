VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Vercel only — conversation logging (api/log-turn.js → Supabase conversation_turns)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vercel only (Settings → Environment Variables) — free key from https://bhashini.gov.in
BHASHINI_API_KEY=your-32-char-bhashini-api-key

# Supabase Edge Functions secrets (Dashboard → Edge Functions → Secrets)
# LOVABLE_API_KEY=your-lovable-or-gemini-key  (Gemini STT fallback)
# BHASHINI_API_KEY=your-32-char-bhashini-api-key  (preferred STT + TTS)
# YOUTUBE_API_KEY=your-youtube-data-api-v3-key
#
# Table: run supabase/setup.sql once in SQL Editor → conversation_turns
# View logs: Supabase → Table Editor → conversation_turns
